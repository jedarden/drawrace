{
  "name": "drawrace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint packages/engine-core/src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "playwright test e2e/a11y.spec.ts",
    "test:snapshot": "playwright test e2e/snapshot.spec.ts --project chromium",
    "test:snapshot:update": "SNAPSHOT_UPDATE=1 playwright test e2e/snapshot.spec.ts --project chromium",
    "test:perf": "playwright test e2e/perf.spec.ts --project perf",
    "test:snap": "docker run --rm -v ${PWD}:/work -w /work -e CI=true ghcr.io/drawrace/ci-snap:2026-04-24 sh -c 'pnpm install && pnpm test:snapshot'",
    "test:snap:update": "docker run --rm -v ${PWD}:/work -w /work -e CI=true -e SNAPSHOT_UPDATE=1 ghcr.io/drawrace/ci-snap:2026-04-24 sh -c 'pnpm install && pnpm test:snapshot'",
    "snap:docker": "docker-compose -f docker-compose.snapshot.yml run --rm snapshot-test",
    "snap:docker:update": "SNAPSHOT_UPDATE=1 docker-compose -f docker-compose.snapshot.yml run --rm snapshot-test",
    "regen-snapshot-fixture": "npx tsx packages/engine-core/scripts/gen-snapshot-fixture.ts && cp packages/engine-core/fixtures/snapshot-fixture.json apps/web/public/fixtures/",
    "regen-golden": "npx tsx packages/engine-core/scripts/regen-golden.ts",
    "e2e:phone-smoke": "bash e2e/phone-smoke/run.sh",
    "e2e:phone-smoke:save-baselines": "bash e2e/phone-smoke/run.sh --save-baselines",
    "size": "size-limit"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^9.24.0",
    "@playwright/test": "^1.59.1",
    "@size-limit/preset-app": "^12.1.0",
    "@types/pixelmatch": "^5.2.6",
    "eslint": "^9.24.0",
    "jsdom": "^29.0.2",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "size-limit": "^11.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.1",
    "vitest": "^3.1.1"
  },
  "size-limit": [
    {
      "name": "engine-core",
      "path": "packages/engine-core/dist/index.js",
      "limit": "100 KB",
      "gzip": true
    },
    {
      "name": "web-app",
      "path": "apps/web/dist/assets/*.js",
      "limit": "400 KB",
      "gzip": true
    }
  ]
}
