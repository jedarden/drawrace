      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "id": 18
    },
    {
      "title": "Validator Pod Availability",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 64 },
      "targets": [
        {
          "expr": "kube_statefulset_status_replicas_ready{statefulset=\"drawrace-validator\"}",
          "legendFormat": "ready",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
