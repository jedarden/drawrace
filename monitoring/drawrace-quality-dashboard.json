{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "DrawRace Quality monitoring dashboard — submission rate, re-sim health, ghost pool, active sessions, error analysis",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Submission Throughput",
      "type": "row"
    },
    {
      "title": "Submission Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(drawrace_validator_submissions_total[5m]))",
          "legendFormat": "submissions/sec",
          "refId": "A"
        },
        {
          "expr": "sum(rate(drawrace_submissions_total{outcome=\"accepted\"}[5m]))",
          "legendFormat": "accepted (api)",
          "refId": "B"
        },
        {
          "expr": "sum(rate(drawrace_submissions_total{outcome=\"ephemeral\"}[5m]))",
          "legendFormat": "ephemeral (api)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "pps" }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "id": 1
    },
    {
      "title": "Total Submissions (24h)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "sum(increase(drawrace_validator_submissions_total[24h]))",
          "legendFormat": "total submissions",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "id": 2
    },
    {
      "title": "Submission Outcome Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "sum(drawrace_validator_accepted_total)",
          "legendFormat": "accepted",
          "refId": "A"
        },
        {
          "expr": "sum(drawrace_validator_rejected_total)",
          "legendFormat": "rejected",
          "refId": "B"
        },
        {
          "expr": "sum(drawrace_validator_quarantined_total)",
          "legendFormat": "quarantined",
          "refId": "C"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut",
        "tooltip": { "mode": "single" }
      },
      "id": 3
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 200,
      "panels": [],
      "title": "Re-sim Health",
      "type": "row"
    },
    {
      "title": "Re-sim Pass Rate (1h)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "sum(rate(drawrace_validator_accepted_total[1h])) / sum(rate(drawrace_validator_submissions_total[1h]))",
          "legendFormat": "pass rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.9 },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.98 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "id": 4
    },
    {
      "title": "Re-sim Pass Rate Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "targets": [
        {
          "expr": "sum(rate(drawrace_validator_accepted_total[5m])) / sum(rate(drawrace_validator_submissions_total[5m]))",
          "legendFormat": "pass rate",
          "refId": "A"
        },
        {
          "expr": "0.98",
          "legendFormat": "98% target",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "decimals": 3 }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "id": 5
    },
    {
      "title": "Validator Queue Depth",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "targets": [
        {
          "expr": "drawrace_validator_queue_depth",
          "legendFormat": "pending jobs",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "id": 6
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 300,
      "panels": [],
      "title": "Latency & Performance",
      "type": "row"
    },
    {
      "title": "API Request Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(drawrace_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}",
          "refId": "A"
        },
        {
          "expr": "0.4",
          "legendFormat": "400ms target",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "id": 7
    },
    {
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "targets": [
        {
          "expr": "sum(rate(drawrace_http_request_duration_seconds_count[5m]))",
          "legendFormat": "total req/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(drawrace_http_request_duration_seconds_count{route=~\"leaderboard|matchmake\"}[5m]))",
          "legendFormat": "read req/s",
          "refId": "B"
        },
        {
          "expr": "sum(rate(drawrace_http_request_duration_seconds_count{route=\"submissions\"}[5m]))",
          "legendFormat": "write req/s",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "id": 8
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 400,
      "panels": [],
      "title": "Ghost Pool & Storage",
      "type": "row"
    },
    {
      "title": "Ghost Blob Storage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "drawrace_ghost_blob_bytes",
          "legendFormat": "total bytes",
          "refId": "A"
        }
