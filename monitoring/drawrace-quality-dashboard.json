    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 },
      "id": 600,
      "panels": [],
      "title": "Error Analysis",
      "type": "row"
    },
    {
      "title": "Rejection Rate by Reason",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 46 },
      "targets": [
        {
          "expr": "sum by (reason) (rate(drawrace_validator_rejected_by_reason_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "id": 14
    },
    {
      "title": "Error Distribution (Pie)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 46 },
      "targets": [
        {
          "expr": "sum by (reason) (drawrace_validator_rejected_by_reason_total)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "pie",
        "tooltip": { "mode": "single" }
      },
      "id": 15
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 },
      "id": 700,
      "panels": [],
      "title": "Physics & Quality Drift",
      "type": "row"
    },
    {
      "title": "Replay Mismatch Rate (Physics Drift Indicator)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 55 },
      "targets": [
        {
          "expr": "sum(rate(drawrace_validator_resim_mismatch_total[5m])) / sum(rate(drawrace_validator_submissions_total[5m]))",
          "legendFormat": "mismatch rate",
          "refId": "A"
        },
        {
          "expr": "0.005",
          "legendFormat": "0.5% alert threshold",
          "refId": "B"
        },
        {
          "expr": "0.01",
          "legendFormat": "1% critical threshold",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "decimals": 4 }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "id": 16
    },
    {
      "title": "Tick Difference Distribution (Drift Analysis)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 55 },
      "targets": [
        {
          "expr": "sum by (diff_bucket) (drawrace_validator_resim_tick_diff)",
          "legendFormat": "{{diff_bucket}} ticks diff",
          "refId": "A"
        }
      ],
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true
      },
      "id": 17
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 63 },
      "id": 800,
      "panels": [],
