    },
    {
      "title": "Active WebSocket Connections",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 },
      "targets": [
        {
          "expr": "drawrace_websocket_connections",
          "legendFormat": "connections",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "id": 11
    },
    {
      "title": "Active Rooms",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 37 },
      "targets": [
        {
          "expr": "drawrace_rooms_active",
          "legendFormat": "rooms",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 50,
          "thresholds": {
            "mode": "absolute",
