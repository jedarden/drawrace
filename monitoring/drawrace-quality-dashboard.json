    },
    {
      "title": "Ghost Pool Growth Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "rate(drawrace_ghost_blob_bytes[1h])",
          "legendFormat": "bytes/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      },
      "id": 10
