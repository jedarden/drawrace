      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 200,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 150 }
            ]
          }
        }
      },
      "options": {
        "orientation": "auto",
