    {
      "title": "Active Racers",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 37 },
      "targets": [
        {
          "expr": "sum(drawrace_racers_active)",
          "legendFormat": "racers",
          "refId": "A"
        }
