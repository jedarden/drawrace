      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "expr": "sum(rate(drawrace_validator_rejected_total[5m])) / sum(rate(drawrace_validator_submissions_total[5m]))",
          "legendFormat": "total rejection rate",
          "refId": "A"
