      "panels": [],
      "title": "Physics Re-simulation Health",
      "type": "row"
    },
    {
      "title": "Overall Rejection Rate (1h)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(drawrace_validator_rejected_total[1h])) / sum(rate(drawrace_validator_submissions_total[1h]))",
          "legendFormat": "rejection rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "orange", "value": 0.025 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "id": 1
    },
    {
      "title": "Resim Mismatch Rate (1h)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(drawrace_validator_resim_mismatch_total[1h])) / sum(rate(drawrace_validator_submissions_total[1h]))",
          "legendFormat": "resim mismatch rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.02 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "id": 2
    },
    {
      "title": "Quarantine Rate (1h)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(drawrace_validator_quarantined_total[1h])) / sum(rate(drawrace_validator_submissions_total[1h]))",
          "legendFormat": "quarantine rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.001 },
              { "color": "red", "value": 0.005 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "id": 3
    },
