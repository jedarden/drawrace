{
  "annotations": { "list": [] },
  "description": "DrawRace CI quality metrics dashboard (plan.md §Testing 14)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Code Coverage (%)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "drawrace_coverage_lines",
          "legendFormat": "lines"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "title": "Test Flake Rate (7d)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "drawrace_flake_rate",
          "legendFormat": "flake rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "title": "Physics Golden Delta Ticks",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "drawrace_physics_golden_max_delta_ticks",
          "legendFormat": "max delta"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Bundle Size (gzipped)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "drawrace_bundle_size_gzip_bytes",
          "legendFormat": "{{bundle}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "max": 450000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 350000 },
              { "color": "red", "value": 400000 }
            ]
          }
        }
      }
    },
    {
      "title": "CI Stage Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "drawrace_ci_duration_seconds",
          "legendFormat": "{{stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Perf Test Frame Times",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "drawrace_perf_frame_p95_ms",
          "legendFormat": "p95"
        },
        {
          "expr": "drawrace_perf_frame_median_ms",
          "legendFormat": "median"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "Coverage Trend (7d)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "drawrace_coverage_lines",
          "legendFormat": "lines"
        },
        {
          "expr": "drawrace_coverage_branches",
          "legendFormat": "branches"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 50,
          "max": 100
        }
      }
    },
    {
      "title": "Bundle Size Trend (7d)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "drawrace_bundle_size_gzip_bytes",
          "legendFormat": "{{bundle}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "title": "Flake Rate by Test (7d)",
      "type": "heatmap",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "drawrace_test_flake_count",
          "legendFormat": "{{test}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "spectrum"
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["drawrace", "ci", "quality"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "title": "DrawRace / CI Quality",
  "uid": "drawrace-ci-quality",
  "refresh": "5m"
}
