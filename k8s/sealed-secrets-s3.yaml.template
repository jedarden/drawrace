---
apiVersion: v1
kind: Secret
metadata:
  name: drawrace-api-s3-credentials
  namespace: drawrace
type: Opaque
stringData:
  # Garage S3 credentials via Tailscale (ardenone-hub)
  AWS_ACCESS_KEY_ID: "REPLACE_WITH_GARAGE_ACCESS_KEY"
  AWS_SECRET_ACCESS_KEY: "REPLACE_WITH_GARAGE_SECRET_KEY"
  AWS_ENDPOINT_URL: "http://garage.ardenone-hub.svc:3900"
  AWS_REGION: "garage"
